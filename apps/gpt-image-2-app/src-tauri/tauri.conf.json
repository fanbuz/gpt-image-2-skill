{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPT Image 2",
  "version": "0.3.1",
  "identifier": "com.wangnov.gpt-image-2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GPT Image 2",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.codex/gpt-image-2-skill/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "appimage", "deb", "rpm"],
    "publisher": "Wangnov",
    "category": "GraphicsAndDesign",
    "shortDescription": "Desktop image generation and editing for GPT Image 2.",
    "longDescription": "GPT Image 2 is a desktop app for generating and editing images with shared CLI, Skill, provider, and credential configuration.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["bin/*"],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "11.0",
      "providerShortName": "3VT538F8B6",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  }
}
