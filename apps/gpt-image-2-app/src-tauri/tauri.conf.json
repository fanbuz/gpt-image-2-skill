{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPT Image 2",
  "version": "0.2.4",
  "identifier": "com.wangnov.gpt-image-2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GPT Image 2",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../../../assets/logo.png"],
    "resources": {
      "bin/gpt-image-2-skill": "bin/gpt-image-2-skill"
    }
  }
}
